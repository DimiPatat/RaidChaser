# ===========================================================================
# Raid Chaser config. Copy this to ".env" and fill in your real values.
# On Render, you add these as "Environment Variables" in the dashboard instead
# of using a file.
# ===========================================================================

# The bot's token from the Discord Developer Portal (Bot tab).
DISCORD_TOKEN=MTUyMDcyMzY2NjE5ODA3MzQ2OA.GfuAt7.v1uSJP5rTPH6HmFlQzsL2TSpwJV-pXjZr50RbQ

# Your Discord server (guild) ID. Right-click server icon > Copy Server ID.
# (You need Developer Mode on in Discord settings > Advanced.)
GUILD_ID=1214714252414296064

# The channel Raid-Helper posts your raid events to.
# Right-click the channel > Copy Channel ID.
SIGNUP_CHANNEL_ID=1401589125189992468,1401589160392790107

# The channel where public "last call" pings go (stage 3).
CHASE_CHANNEL_ID=1255523886502645840

# The officer-only channel where the missing-list summary is posted.
OFFICER_CHANNEL_ID=1214714533537648761

# Role IDs to SEED the chase list on first run, comma-separated. OPTIONAL.
# After first run you manage roles live in Discord with /roles add and /roles remove.
# Leave blank if you'd rather add them by hand once the bot is running.
RAIDER_ROLE_IDS=1360691461410128114,1214948384906154105,1316537951974457464

# Where the live role list is stored.
# On Render, point this at a persistent disk mount (e.g. /data/roles.json)
# so it survives redeploys. See README Step 4 for how to set that up.
ROLES_FILE=roles.json

# How many hours ahead to scan for events. 48 is plenty for Mon/Wed.
LOOKAHEAD_HOURS=48

# PORT is set automatically by Render - do NOT add this yourself.
# The keepalive web server reads it to know which port to listen on.
